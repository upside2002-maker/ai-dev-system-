{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aida.local/schemas/decision.schema.json",
  "title": "decision",
  "description": "Решение Owner'а/ролей: выбор, не факт о мире. Лежит в ledger/decisions.jsonl, пишется только через aida. Дописываемый (И-14).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "decision",
    "decided_by",
    "decided_at",
    "scope",
    "basis",
    "review_when",
    "status",
    "supersedes",
    "recorded_by",
    "recorded_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^D-[0-9]{8}-[0-9]{3}$",
      "description": "D-YYYYMMDD-NNN; NNN — порядковый за день, уникален в файле."
    },
    "decision": {
      "type": "string",
      "minLength": 1,
      "description": "Что решено, одним-двумя предложениями."
    },
    "decided_by": {
      "type": "string",
      "enum": ["owner", "admin", "tl-sitka", "tl-astro"]
    },
    "decided_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "YYYY-MM-DD — дата решения из DISPATCHER/журнала, не выдуманная."
    },
    "scope": {
      "type": "string",
      "enum": ["system", "global", "sitka-office", "astro", "aida-voice", "crypto"]
    },
    "basis": {
      "type": "array",
      "items": { "type": "string" },
      "description": "id фактов и/или свободный текст («надиктовка 11.06»)."
    },
    "review_when": {
      "description": "Условие пересмотра либо null.",
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "status": {
      "type": "string",
      "enum": ["active", "superseded", "revoked"]
    },
    "supersedes": {
      "description": "id решения, которое эта запись заменяет, либо null.",
      "oneOf": [
        { "type": "string", "pattern": "^D-[0-9]{8}-[0-9]{3}$" },
        { "type": "null" }
      ]
    },
    "recorded_by": {
      "type": "string",
      "minLength": 1
    },
    "recorded_at": {
      "type": "string",
      "description": "Момент записи (ISO-8601)."
    }
  }
}
